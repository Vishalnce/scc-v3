
model SmallQuiz {
  id            String   @id @default(uuid())

  questionText  String?  // optional text

 
  options       Json     // Example: [{ text: "Option 1", image: "url" }, { text: "Option 2"// }]

  solutionText  String?

  correctOption Int
  marksPositive Float
  marksNegative Float
  level         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
