
model SmallQuiz {
  id            String   @id @default(uuid())

  questionText  String?  // optional text

 
  options       Json     // Example: [{ text: "Option 1", image: "url" }, { text: "Option 2"// }]



  correctOption Int
 
 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
