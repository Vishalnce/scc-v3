model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  image       String
  alt         String
  topic       String
  summary     String
  keywords    String
  description String
  editorHtml  String
  toc         String
  timeLimit Float     @default(15)
  createdAt   DateTime  @default(now())

  quizposts   PostQuiz[]
    comments    Comment[]

    notifications Notification[]
}

model PostQuiz {

  
  id            String   @id @default(uuid())
  postId        Int
  post          Post     @relation(fields: [postId], references: [id],onDelete: Cascade)
  questionText  String?  // optional text

  options       Json     // Example: [{ text: "Option 1", image: "url" }, { text: "Option 2"// }]

  solutionText  String?

  correctOption Int
  marksPositive Float
  marksNegative Float
  level         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


