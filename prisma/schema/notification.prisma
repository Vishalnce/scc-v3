model Notification {
  id          String        @id @default(cuid())
  title       String
  path String


  createdAt   DateTime      @default(now())
  

  // relations (optional)

  quizId      Int?
  quiz        Quiz?         @relation(fields: [quizId], references: [id])

  currentAffairId Int?
  currentAffair    Post? @relation(fields: [currentAffairId], references: [id])


}

