model Notification {
  id          String        @id @default(cuid())
  title       String          @unique //useful for delete
  path String


  createdAt   DateTime      @default(now())
  

  // relations (optional)

  quizId      Int?
  quiz        Quiz?         @relation(fields: [quizId], references: [id],onDelete: Cascade)

  currentAffairId Int?
  currentAffair    Post? @relation(fields: [currentAffairId], references: [id],onDelete: Cascade)


}

